# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Authentication
JWT_SECRET=your-secret-key-here

# LLM Provider (openai or gemini)
LLM_PROVIDER=gemini

# OpenAI (optional - only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key

# Google Gemini (recommended - free tier available)
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Server
PORT=3000
NODE_ENV=development

# Inngest (for scheduled tasks)
# Get your signing key from https://app.inngest.com
# Leave empty for local development
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# bundle.social (for publishing to social platforms)
# Get your API key from https://app.bundle.social → Settings → API Keys
BUNDLE_SOCIAL_API_KEY=pk_live_...
# Get your Team ID from https://app.bundle.social → Settings → Team
BUNDLE_SOCIAL_TEAM_ID=team_...

# Hugging Face (for image generation via FLUX.1-schnell)
# Get free API key from https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# fal.ai (for video generation via LTX-Video)
# Get API key from https://fal.ai/dashboard/keys (~$1 free credit on signup)
FAL_API_KEY=

# MiniMax / Hailuo (for video generation - 100 free credits on signup = ~142 videos)
# Get API key from https://platform.minimax.io
MINIMAX_API_KEY=
